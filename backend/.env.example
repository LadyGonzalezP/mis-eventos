# Copia este archivo como .env y completa los valores.
# El .env real NUNCA se sube al repositorio (esta en .gitignore).

# ============================================
# Base de datos
# ============================================
DATABASE_URL=postgresql://postgres:postgres@db:5432/mis_eventos
# Para local sin Docker: postgresql://postgres:postgres@localhost:5432/mis_eventos

# ============================================
# JWT - Autenticacion
# ============================================
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=cambiame-por-un-secret-aleatorio-de-32-bytes-minimo
JWT_EXPIRATION_HOURS=24

# ============================================
# CORS
# ============================================
# Whitelist de origenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# Observabilidad
# ============================================
LOG_LEVEL=INFO

# ============================================
# App metadata
# ============================================
APP_VERSION=0.1.0

# ============================================
# Bonus IA (opcional) - Generacion de descripciones de eventos con Groq
# ============================================
# Obtener key gratis en https://console.groq.com/keys
# Si no se setea, el endpoint POST /api/v1/ai/generate-description devuelve 503
# (el resto del sistema funciona normal sin IA)
GROQ_API_KEY=tu-groq-api-key-aqui
